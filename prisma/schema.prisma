// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Reservation {
  id          Int                 @id @default(autoincrement())
  lastName    String              @map("last_name")
  displayName String              @map("display_name")
  maxSeats    Int                 @map("max_seats")
  members     ReservationMember[]
  rsvp        Rsvp?

  @@index([lastName])
  @@map("reservation")
}

model ReservationMember {
  id                     Int            @id @default(autoincrement())
  reservationId          Int            @map("reservation_id")
  firstName              String         @map("first_name")
  hasPlusOne             Boolean        @default(false) @map("has_plus_one")
  rehearsalDinnerInvited Boolean        @default(false) @map("rehearsal_dinner_invited")
  reservation            Reservation    @relation(fields: [reservationId], references: [id])
  rsvpAttendee           RsvpAttendee?
  plusOnesBrought        RsvpAttendee[] @relation("PlusOneBroughtBy")

  @@map("reservation_member")
}

model Rsvp {
  id            Int            @id @default(autoincrement())
  reservationId Int            @unique @map("reservation_id")
  submittedAt   DateTime       @default(now()) @map("submitted_at")
  reservation   Reservation    @relation(fields: [reservationId], references: [id])
  attendees     RsvpAttendee[]

  @@map("rsvp")
}

model RsvpAttendee {
  id                       Int                @id @default(autoincrement())
  rsvpId                   Int                @map("rsvp_id")
  reservationMemberId      Int?               @unique @map("reservation_member_id")
  plusOneName              String?            @map("plus_one_name")
  broughtByMemberId        Int?               @map("brought_by_member_id")
  mealChoice               String             @map("meal_choice")
  dietaryRestrictions      String?            @map("dietary_restrictions")
  rehearsalDinnerAttending Boolean?           @map("rehearsal_dinner_attending")
  rsvp                     Rsvp               @relation(fields: [rsvpId], references: [id])
  reservationMember        ReservationMember? @relation(fields: [reservationMemberId], references: [id])
  broughtByMember          ReservationMember? @relation("PlusOneBroughtBy", fields: [broughtByMemberId], references: [id])

  @@map("rsvp_attendee")
}
